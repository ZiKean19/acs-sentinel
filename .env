# ACS Sentinel — Environment Variables
# NEVER commit this file to git. It is listed in .gitignore.

# ── React Frontend ────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:5000

# ── LocalStack endpoint (used by Python scripts) ──────────────────────────────
LOCALSTACK_URL=http://localhost:4566

# ── Telegram Bot (optional — alerts go to console if not set) ─────────────────
TELEGRAM_BOT_TOKEN=8652965990:AAHoLQtompgcWdHBiswzbe839aTJqyQ7PRQ
TELEGRAM_CHAT_ID=6480334291

# ── DynamoDB table names ──────────────────────────────────────────────────────
DYNAMODB_TABLE_BLOCKED_IPS=blocked-ips
DYNAMODB_TABLE_ALERTS=alerts
DYNAMODB_TABLE_LOG_STREAM=log-stream

# ── Kinesis ───────────────────────────────────────────────────────────────────
KINESIS_STREAM_NAME=security-stream

# ── CloudWatch ────────────────────────────────────────────────────────────────
CLOUDWATCH_LOG_GROUP=security-logs

# ── ML settings ───────────────────────────────────────────────────────────────
ISOLATION_FOREST_CONTAMINATION=0.05
ANOMALY_SCORE_THRESHOLD=-0.15

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=local
